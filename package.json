{
  "name": "jwt-webtool",
  "version": "1.1.6",
  "description": "web tool to parse, generate, and validate JWT, whether signed or encrypted",
  "repository": {
    "type": "git",
    "url": "git://github.com/DinoChiesa/jwt-webtool.git"
  },
  "main": "webpack.config.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "webpack --output-pathinfo --devtool source-map --mode=development --watch --color",
    "devbuild": "webpack --output-pathinfo --devtool source-map --mode=development --progress --color",
    "build": "webpack --mode=production --progress --color",
    "build:pages": "webpack --mode=production --progress --color",
    "clean": "shx rm -f pnpm-lock.yaml && shx rm -fr node_modules dist"
  },
  "keywords": ["JWT", "node-jose"],
  "author": "Dino Chiesa <dchiesa@google.com>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "codemirror": "^5.65.2",
    "node-jose": "^2.2.0"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^26.1.0",
    "mini-css-extract-plugin": "^2.9.4",
    "shx": "^0.4.0",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.6",
    "vitest": "^3.2.4",
    "webpack": "^5.102.1",
    "webpack-cli": "^4.10.0"
  },
  "engines": {
    "node": ">= 22.16.0",
    "pnpm": ">= 10.9.0"
  },
  "pnpm": {
    "overrides": {
      "node-forge": "^1.3.2",
      "lodash": "^4.17.23",
      "serialize-javascript": "^7.0.5",
      "uuid": "^11.1.1",
      "esbuild": "^0.28.1"
    }
  }
}